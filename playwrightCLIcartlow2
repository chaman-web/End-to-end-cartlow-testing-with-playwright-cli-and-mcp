                "file_text": "import os\nimport random\nimport pytest\nfrom playwright.sync_api import Page\n\nBASE_URL = \"https://stage.cartlow.com/uae/en\"\n\nDB_HOST = os.getenv(\"DB_HOST\", \"localhost\")\nDB_PORT = os.getenv(\"DB_PORT\", \"5432\")\nDB_NAME = os.getenv(\"DB_NAME\", \"cartlow\")\nDB_USER = os.getenv(\"DB_USER\", \"postgres\")\nDB_PASS = os.getenv(\"DB_PASS\", \"\")\n\n\ndef get_otp_from_db(recipient: str):\n    try:\n        import psycopg2\n        conn = psycopg2.connect(host=DB_HOST, port=DB_PORT, database=DB_NAME, user=DB_USER, password=DB_PASS)\n        cur = conn.cursor()\n        cur.execute(\n            \"SELECT otp FROM otp_verification WHERE recipient = %s ORDER BY created_at DESC LIMIT 1\",\n            (recipient,)\n        )\n        row = cur.fetchone()\n        cur.close()\n        conn.close()\n        return str(row[0]) if row else None\n    except Exception as e:\n        print(f\"\\n⚠️  DB not reachable: {e}\")\n        return None\n\n\ndef open_register_form(page: Page):\n    \"\"\"Open the site, trigger auth modal, switch to Create Account tab.\"\"\"\n    page.goto(BASE_URL, wait_until=\"domcontentloaded\")\n    page.wait_for_timeout(8000)\n\n    # Open auth modal via Vue emitter\n    for _ in range(10):\n        try:\n            page.evaluate(\n                \"document.querySelector('#app').__vue_app__.config.globalProperties.$emitter.emit('open-customer-auth-modal')\"\n            )\n            page.wait_for_selector(\"#login-email\", state=\"visible\", timeout=5000)\n            break\n        except Exception:\n            page.wait_for_timeout(2000)\n\n    # Click \"Create Account\" tab using mouse coordinates (span is at x=640,y=116 w=186 h=53)\n    page.mouse.click(733, 142)  # center of Create Account tab\n    page.wait_for_selector(\"#register-email\", state=\"visible\", timeout=10000)\n\n\ndef test_registration_positive_flow(page: Page):\n    test_email = f\"test_{random.randint(10000, 99999)}@cartlow.com\"\n    print(f\"\\n📧 Registering with: {test_email}\")\n\n    # Step 1: Open registration form\n    open_register_form(page)\n    print(\"✅ Step 1: Registration form opened\")\n\n    # Step 2: Enter email and click Continue\n    page.locator(\"#register-email\").fill(test_email)\n    page.wait_for_timeout(500)\n    assert page.locator(\"button:has-text('Continue')\").get_attribute(\"disabled\") is None, \\\n        \"Continue button should be enabled after typing email\"\n    page.locator(\"button:has-text('Continue')\").click()\n    page.wait_for_timeout(6000)\n    print(\"✅ Step 2: Email submitted\")\n\n    # Step 3: OTP screen should appear — Verify button is the signal\n    page.wait_for_selector(\"button:has-text('Verify')\", state=\"visible\", timeout=10000)\n    print(\"✅ Step 3: OTP screen appeared\")\n\n    # Find OTP input — it's the first visible input that is NOT the search bar\n    otp_input = None\n    for inp in page.locator(\"input\").all():\n        try:\n            if inp.is_visible() and inp.get_attribute(\"placeholder\") != \"Search products here\":\n                otp_input = inp\n                break\n        except:\n            pass\n    assert otp_input is not None, \"OTP input not found on screen\"\n\n    # Step 4: Get OTP from DB or wait for manual entry\n    otp = get_otp_from_db(test_email)\n    if otp:\n        print(f\"✅ Step 4: OTP fetched from DB: {otp}\")\n        otp_input.fill(otp)\n    else:\n        print(\"⏳ Step 4: DB not available — please enter the OTP manually in the browser window.\")\n        input(\"   Press Enter here after you have typed the OTP in the browser: \")\n\n    page.wait_for_timeout(500)\n\n    # Step 5: Click Verify\n    page.locator(\"button:has-text('Verify')\").click()\n    page.wait_for_timeout(6000)\n    print(\"✅ Step 5: Verify clicked\")\n\n    # Step 6: Assert logged-in state\n    body = page.locator(\"body\").inner_text().lower()\n    assert any(k in body for k in [\"logout\", \"my account\", \"welcome\", \"sign out\"]), \\\n        f\"Expected logged-in state after registration. Page text: {body[:300]}\"\n    print(\"✅ Step 6: Registration successful — user is logged in\")\n",
