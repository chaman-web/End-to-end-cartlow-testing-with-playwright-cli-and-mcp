le buttons:\")\n    for btn in page.locator(\"button\").all():\n        try:\n            t = btn.inner_text().strip()\n            if btn.is_visible() and t and len(t) < 30:\n                print(f\"  '{t}' disabled={btn.get_attribute('disabled')}\")\n        except: pass\n\n    browser.close()\nEOF\n2>&1",
