                    "Text": "=== Operation 1 Result (Text) ===\nimport pytest\nimport os\nfrom playwright.sync_api import Page\n\nBASE_URL = \"https://stage.cartlow.com/uae/en\"\nVALID_EMAIL = \"muhammad.akmal@cartlow.com\"\nVALID_PASSWORD = \"Test!123\"\n\nDB_HOST = os.getenv(\"DB_HOST\", \"localhost\")\nDB_PORT = os.getenv(\"DB_PORT\", \"5432\")\nDB_NAME = os.getenv(\"DB_NAME\", \"cartlow\")\nDB_USER = os.getenv(\"DB_USER\", \"postgres\")\nDB_PASS = os.getenv(\"DB_PASS\", \"\")\n\n\ndef get_otp_from_db(recipient: str):\n    \"\"\"Fetch OTP from otp_verification table.\"\"\"\n    try:\n        import psycopg2\n        conn = psycopg2.connect(host=DB_HOST, port=DB_PORT, database=DB_NAME, user=DB_USER, password=DB_PASS)\n        cur = conn.cursor()\n        cur.execute(\"SELECT otp FROM otp_verification WHERE recipient = %s ORDER BY created_at DESC LIMIT 1\", (recipient,))\n        row = cur.fetchone()\n        cur.close()\n        conn.close()\n        return row[0] if row else None\n    except Exception as e:\n        print(f\"❌ DB error: {e}\")\n        return None\n\n\ndef open_login_modal(page: Page):\n    page.goto(BASE_URL, wait_until=\"domcontentloaded\")\n    page.wait_for_timeout(8000)\n    for _ in range(10):\n        try:\n            page.evaluate(\"document.querySelector('#app').__vue_app__.config.globalProperties.$emitter.emit('open-customer-auth-modal')\")\n            break\n        except Exception:\n            page.wait_for_timeout(2000)\n    page.wait_for_selector(\"#login-email\", state=\"visible\", timeout=20000)\n\n\ndef do_login(page: Page, email: str, password: str):\n    open_login_modal(page)\n    page.fill(\"#login-email\", email)\n    page.fill(\"#login-password\", password)\n    page.locator(\"button:has-text('Sign In')\").first.click()\n    page.wait_for_timeout(5000)\n\n\n# ── Login Tests ───────────────────────────────────────────────────────────────\n\ndef test_valid_login(page: Page):\n    do_login(page, VALID_EMAIL, VALID_PASSWORD)\n    body = page.locator(\"body\").inner_text().lower()\n    assert any(k in body for k in [\"logout\", \"my account\", \"sign out\", \"account\"])\n    print(\"✅ Valid login\")\n\n\ndef test_invalid_password(page: Page):\n    do_login(page, VALID_EMAIL, \"WrongPass999!\")\n    page.wait_for_timeout(2000)\n    body = page.locator(\"body\").inner_text().lower()\n    assert any(k in body for k in [\"invalid\", \"incorrect\", \"wrong\", \"error\", \"failed\", \"credentials\"])\n    print(\"✅ Invalid password\")\n\n\ndef test_invalid_email(page: Page):\n    do_login(page, \"nonexistent_xyz_123@cartlow.com\", \"Test!123\")\n    page.wait_for_timeout(2000)\n    body = page.locator(\"body\").inner_text().lower()\n    assert any(k in body for k in [\"invalid\", \"incorrect\", \"wrong\", \"error\", \"failed\", \"not found\", \"credentials\"])\n    print(\"✅ Invalid email\")\n\n\ndef test_empty_credentials(page: Page):\n    open_login_modal(page)\n    page.locator(\"button:has-text('Sign In')\").first.click()\n    page.wait_for_timeout(2000)\n    body = page.locator(\"body\").inner_text().lower()\n    assert any(k in body for k in [\"required\", \"invalid\", \"enter\", \"empty\", \"field\"])\n    print(\"✅ Empty credentials\")\n\n\ndef test_empty_password(page: Page):\n    open_login_modal(page)\n    page.fill(\"#login-email\", VALID_EMAIL)\n    page.locator(\"button:has-text('Sign In')\").first.click()\n    page.wait_for_timeout(2000)\n    body = page.locator(\"body\").inner_text().lower()\n    assert any(k in body for k in [\"required\", \"invalid\", \"enter\", \"password\", \"field\"])\n    print(\"✅ Empty password\")\n\n\ndef test_empty_email(page: Page):\n    open_login_modal(page)\n    page.fill(\"#login-password\", VALID_PASSWORD)\n    page.locator(\"button:has-text('Sign In')\").first.click()\n    page.wait_for_timeout(2000)\n    body = page.locator(\"body\").inner_text().lower()\n    assert any(k in body for k in [\"required\", \"invalid\", \"enter\", \"email\", \"field\"])\n    print(\"✅ Empty email\")\n\n\ndef test_invalid_email_format(page: Page):\n    open_login_modal(page)\n    page.fill(\"#login-email\", \"not-an-email\")\n    page.fill(\"#login-password\", \"Test!123\")\n    page.locator(\"button:has-text('Sign In')\").first.click()\n    page.wait_for_timeout(2000)\n    body = page.locator(\"body\").inner_text().lower()\n    assert any(k in body for k in [\"invalid\", \"valid email\", \"format\", \"error\"]) or page.locator(\"#login-email:invalid\").count() > 0\n    print(\"✅ Invalid email format\")\n\n\ndef test_logout(page: Page):\n    do_login(page, VALID_EMAIL, VALID_PASSWORD)\n    for label in [\"Logout\", \"Sign Out\", \"Log Out\"]:\n        btn = page.locator(f\"a:has-text('{label}'), button:has-text('{label}')\").first\n        if btn.is_visible():\n            btn.click()\n            break\n    else:\n        page.locator(\"a:has-text('My Account'), button:has-text('Account')\").first.click()\n        page.wait_for_timeout(1000)\n        for label in [\"Logout\", \"Sign Out\", \"Log Out\"]:\n            btn = page.locator(f\"a:has-text('{label}'), button:has-text('{label}')\").first\n            if btn.is_visible():\n                btn.click()\n                break\n    page.wait_for_timeout(4000)\n    body = page.locator(\"body\").inner_text().lower()\n    assert any(k in body for k in [\"sign in\", \"login\", \"register\"])\n    print(\"✅ Logout\")\n\n\n# ── Registration Tests ────────────────────────────────────────────────────────\n\ndef test_registration_valid_email(page: Page):\n    import random\n    test_email = f\"test_{random.randint(10000, 99999)}@cartlow.com\"\n    \n    open_login_modal(page)\n    page.get_by_text(\"Create Account\").click()\n    page.wait_for_timeout(2000)\n    \n    # Fill email\n    page.locator(\"#register-email\").fill(test_email)\n    page.wait_for_timeout(2000)\n    \n    # Click Continue button\n    page.get_by_role(\"button\", name=\"Continue\").click()\n    page.wait_for_timeout(5000)\n    \n    # Check if OTP screen appears\n    body = page.locator(\"body\").inner_text().lower()\n    if \"otp\" in body or \"verification\" in body or \"code\" in body:\n        otp = get_otp_from_db(test_email)\n        assert otp, f\"OTP not found for {test_email}\"\n        print(f\"  OTP from DB: {otp}\")\n        \n        # Enter OTP\n        page.locator(\"input[type='text']\").first.fill(str(otp))\n        page.wait_for_timeout(1000)\n        \n        # Click verify button\n        page.get_by_role(\"button\", name=\"Verify\").or_(page.get_by_role(\"button\", name=\"Continue\")).click()\n        page.wait_for_timeout(5000)\n        \n        body = page.locator(\"body\").inner_text().lower()\n        assert any(k in body for k in [\"success\", \"welcome\", \"account\", \"logout\"])\n        print(f\"✅ Registration: {test_email}\")\n    else:\n        print(f\"⚠️  No OTP step\")\n\n\ndef test_registration_valid_phone(page: Page):\n    import random\n    test_phone = f\"+971{random.randint(500000000, 599999999)}\"\n    \n    open_login_modal(page)\n    page.get_by_text(\"Create Account\").click()\n    page.wait_for_timeout(2000)\n    \n    # Fill phone\n    page.locator(\"input[type='tel']\").or_(page.locator(\"input[type='text']\")).first.fill(test_phone)\n    page.wait_for_timeout(1000)\n    \n    # Click enabled button\n    page.locator(\"button:not([disabled])\").first.click()\n    page.wait_for_timeout(5000)\n    \n    body = page.locator(\"body\").inner_text().lower()\n    if \"otp\" in body or \"verification\" in body or \"code\" in body:\n        otp = get_otp_from_db(test_phone)\n        assert otp, f\"OTP not found for {test_phone}\"\n        print(f\"  OTP from DB: {otp}\")\n        \n        otp_input = page.locator(\"input[type='text']\").or_(page.locator(\"input[type='number']\")).first\n        otp_input.fill(str(otp))\n        page.wait_for_timeout(1000)\n        \n        page.locator(\"button:not([disabled])\").first.click